---
export interface Props {
  title: string;
  company: string;
  dateRange: string;
  summary: string;
}

const { title, company, dateRange, summary } = Astro.props;
---

<div
  class="min-h-36 flex flex-col justify-between gap-y-2 border border-neutral-700 bg-themeBlack hover:scale-105 ease-out transition-transform p-4 rounded-xl"
>
  <div class="flex flex-col gap-y-2">
    <span class="text-xl font-medium text-themeMain">{title}</span>
    <p class="text-(sm neutral-200)">{summary}</p>
  </div>
  <div class="flex items-center gap-x-2 text-(sm neutral-200) shrink-0">
    <span class="text-(sm neutral-200) truncate min-w-0">{company}</span>
    <span>•</span>
    <span class="shrink-0">{dateRange}</span>
  </div>
</div>
